                ].map((t, i) => {
                  const espnMap = { GSW: 'gs', NYK: 'ny', SAS: 'sa', NOP: 'no', UTA: 'utah', PHO: 'phx', WAS: 'wsh', BRK: 'bkn', CHO: 'cha' };
                  const espn = espnMap[t.abbr] ?? t.abbr.toLowerCase();
                  const logo = `https://a.espncdn.com/i/teamlogos/nba/500/${espn}.png`;
                  return (
                    <tr style={`border-bottom: ${i < 2 ? "1px solid #1e2a45" : "none"}; background: ${i % 2 === 0 ? "#182338" : "#1a2640"};`}>
                      <td style="padding: 8px 14px;">
                        <div style="display: flex; align-items: center; gap: 8px;">
                          <img src={logo} alt={t.abbr} style="width: 30px; height: 30px; object-fit: contain; flex-shrink: 0;" />
