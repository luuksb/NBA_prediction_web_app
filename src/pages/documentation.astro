                  <th style="padding: 10px 14px; text-align: left; color: #8fa3c1; font-size: 11px; font-weight: 600; letter-spacing: 0.05em; width: 12.5%;">Availability</th>
                  <th style="padding: 10px 14px; text-align: left; color: #8fa3c1; font-size: 11px; font-weight: 600; letter-spacing: 0.05em; width: 12.5%;">Finals Appearances</th>
                  <th style="padding: 10px 14px; text-align: left; color: #8fa3c1; font-size: 11px; font-weight: 600; letter-spacing: 0.05em; width: 14%;">Finals w/ Star Injured</th>
                  <th style="padding: 10px 14px; text-align: left; color: #8fa3c1; font-size: 11px; font-weight: 600; letter-spacing: 0.05em; width: 11%;">Win Rate (Healthy)</th>
                  <th style="padding: 10px 14px; text-align: left; color: #8fa3c1; font-size: 11px; font-weight: 600; letter-spacing: 0.05em; width: 12.5%;">Win Rate (Injured)</th>
                  <th style="padding: 10px 14px; text-align: left; color: #8fa3c1; font-size: 11px; font-weight: 600; letter-spacing: 0.05em; width: 12.5%;">Drop</th>
                </tr>
              </thead>
              <tbody>
                {[
                  { abbr: "OKC", bpm: "11.7", avail: "99%", finals: "25,321", injured: "250 (1.0%)",    healthy: "83.0%", injRate: "66.8%", drop: "−16.2pp" },
                  { abbr: "DEN", bpm: "14.2", avail: "99%", finals: "11,437", injured: "94 (0.8%)",    healthy: "55.8%", injRate: "34.0%", drop: "−21.8pp" },
