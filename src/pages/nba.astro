---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import NBADashboard from '../components/nba/NBADashboard.jsx';
---

<Base
  title="NBA Championship Model 2025"
  description="50,000-simulation Monte Carlo bracket predictions for the 2025 NBA playoffs. Logistic regression model trained on 2000–2024 playoff data."
  ogImage="/og-nba.png"
>
  <Nav />

  <main class="w-full pl-4 sm:pl-6 pr-8 sm:pr-12 py-6" style="max-width: 1600px; margin-left: auto; margin-right: auto;">
    <NBADashboard client:load />
  </main>
</Base>
