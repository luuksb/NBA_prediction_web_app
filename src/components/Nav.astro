---
const currentPath = Astro.url.pathname;
---

<nav class="border-b border-court-border bg-court-bg/90 backdrop-blur-sm sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between">
    <a href="/" class="text-white font-bold text-sm tracking-wide hover:text-court-accent transition-colors">
      Luuk&rsquo;s NBA Model
    </a>
    <div class="flex gap-6 text-sm">
      <a
        href="/nba"
        class:list={[
          'transition-colors',
          currentPath.startsWith('/nba')
            ? 'text-court-accent font-semibold'
            : 'text-court-text hover:text-white',
        ]}
      >
        2025 Bracket
      </a>
    </div>
  </div>
</nav>
