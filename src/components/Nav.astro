---
const currentPath = Astro.url.pathname;
---

<nav class="border-b border-court-border bg-court-bg/90 backdrop-blur-sm sticky top-0 z-50">
  <div class="w-full pl-4 sm:pl-6 pr-8 sm:pr-12 py-3 flex items-center" style="max-width: 1600px; margin-left: auto; margin-right: auto;">
    <div class="flex gap-6 text-sm">
      <a
        href="/nba"
        class:list={[
          'transition-colors',
          currentPath.startsWith('/nba')
            ? 'text-court-accent font-semibold'
            : 'text-court-text hover:text-white',
        ]}
      >
        Dashboard
      </a>
      <a
        href="/documentation"
        class:list={[
          'transition-colors',
          currentPath.startsWith('/documentation')
            ? 'text-court-accent font-semibold'
            : 'text-court-text hover:text-white',
        ]}
      >
        Documentation
      </a>
    </div>
  </div>
</nav>
